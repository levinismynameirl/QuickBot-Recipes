# Documentation - can be reviewed by docs team
/docs/ @quickbot/docs-team @quickbot/core-team

# GitHub configuration - core team only
/.github/ @quickbot/core-team

# CI/CD workflows - require core team approval
/.github/workflows/ @quickbot/core-team @quickbot/devops-team

# Aliases - require careful review
/aliases/ @quickbot/core-team

# Command scripts - core team only
/cmd/ @quickbot/core-team
/audit_exceptions/ @quickbot/core-team
